pipeline {
    agent {
        kubernetes {
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                  containers:
                  - name: docker
                    image: docker:27-cli
                    command: ['cat']
                    tty: true
                    volumeMounts:
                    - name: docker-sock
                      mountPath: /var/run/docker.sock
                  - name: node
                    image: node:20-bullseye-slim
                    command: ['cat']
                    tty: true
                  volumes:
                  - name: docker-sock
                    hostPath:
                      path: /var/run/docker.sock
            '''
            defaultContainer 'docker'
        }
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        BACKEND_IMAGE_NAME = 'katsdros/fabric-backend'
        FRONTEND_IMAGE_NAME = 'katsdros/fabric-frontend'
        IMAGE_TAG = "v${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/drososkats/fabric-smart-warehouse.git',
                credentialsId: 'github-credentials'
            }
        }

        stage('Guard: Skip if Jenkins-authored commit') {
            steps {
                script {
                    //init the folder as safe before run any git command
                    sh "git config --global --add safe.directory '${env.WORKSPACE}'"
                    def lastMsg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    if (lastMsg.contains('[skip-jenkins]')) {
                        echo "Last commit was authored by Jenkins automation, skipping pipeline."
                        currentBuild.result = 'SUCCESS'
                        error("Skipping: Jenkins-authored commit detected")
                    }
                }
            }
        }

        stage('Backend: Unit Tests') {
            when {
                changeset "backend/**"
            }
            steps {
                container('node') {
                    dir('backend') {
                        sh 'npm install && npm test'
                    }
                }
            }
        }

        stage('Backend: Security Audit') {
            when {
                changeset "backend/**"
            }
            steps {
                container('node') {
                    dir('backend') {
                        sh 'npm install && npm audit --audit-level=critical'
                    }
                }
            }
        }

        stage('Backend: Build Docker Image') {
            when {
                changeset "backend/**"
            }
            steps {
                dir('backend') {
                    sh "docker build -t ${BACKEND_IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Backend: Push to Docker Hub') {
            when {
                changeset "backend/**"
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
                                usernameVariable: 'DOCKERHUB_USR',
                                passwordVariable: 'DOCKERHUB_PSW')]) {
                    sh "echo \${DOCKERHUB_PSW} | docker login -u \${DOCKERHUB_USR} --password-stdin"
                    sh "docker push ${BACKEND_IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('Backend: Update Deployment Manifest') {
            when {
                changeset "backend/**"
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials',
                                usernameVariable: 'GIT_USR',
                                passwordVariable: 'GIT_PSW')]) {
                    sh """
                        sed -i 's|katsdros/fabric-backend:v[0-9]*|katsdros/fabric-backend:${IMAGE_TAG}|' kubernetes/backend-deployment.yaml
                        git config user.email 'jenkins@fabric-vm.local'
                        git config user.name 'Jenkins CI'
                        git add kubernetes/backend-deployment.yaml
                        git commit -m "ci: auto-update backend image to ${IMAGE_TAG} [skip-jenkins]" || echo "Nothing to commit"
                        git push https://\${GIT_USR}:\${GIT_PSW}@github.com/drososkats/fabric-smart-warehouse.git main
                    """
                }
            }
        }

        stage('Frontend: Build Docker Image') {
            when {
                changeset "frontend/**"
            }
            steps {
                dir('frontend') {
                    sh "docker build -t ${FRONTEND_IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Frontend: Push to Docker Hub') {
            when {
                changeset "frontend/**"
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
                                usernameVariable: 'DOCKERHUB_USR',
                                passwordVariable: 'DOCKERHUB_PSW')]) {
                    sh "echo \${DOCKERHUB_PSW} | docker login -u \${DOCKERHUB_USR} --password-stdin"
                    sh "docker push ${FRONTEND_IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('Frontend: Update Deployment Manifest') {
            when {
                changeset "frontend/**"
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials',
                                usernameVariable: 'GIT_USR',
                                passwordVariable: 'GIT_PSW')]) {
                    sh """
                        sed -i 's|katsdros/fabric-frontend:v[0-9]*|katsdros/fabric-frontend:${IMAGE_TAG}|' kubernetes/frontend-deployment.yaml
                        git config user.email 'jenkins@fabric-vm.local'
                        git config user.name 'Jenkins CI'
                        git add kubernetes/frontend-deployment.yaml
                        git commit -m "ci: auto-update frontend image to ${IMAGE_TAG} [skip-jenkins]" || echo "Nothing to commit"
                        git push https://\${GIT_USR}:\${GIT_PSW}@github.com/drososkats/fabric-smart-warehouse.git main
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline completed (build #${BUILD_NUMBER})."
        }
        failure {
            echo "❌ Build failed."
        }
    }
}
