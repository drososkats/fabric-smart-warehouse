pipeline {
    agent {
        kubernetes {
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                  containers:
                  - name: docker
                    image: docker:27-cli
                    command: ['cat']
                    tty: true
                    volumeMounts:
                    - name: docker-sock
                      mountPath: /var/run/docker.sock
                  - name: node
                    image: node:20-bullseye-slim
                    command: ['cat']
                    tty: true
                  volumes:
                  - name: docker-sock
                    hostPath:
                      path: /var/run/docker.sock
            '''
            defaultContainer 'docker'
        }
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        IMAGE_NAME = 'katsdros/fabric-backend'
        IMAGE_TAG = "v${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/drososkats/fabric-smart-warehouse.git',
                credentialsId: 'github-credentials'
            }
        }
    
    stage('Check for Backend Changes') {
    steps {
        script {
            def changes = sh(
                script: "git diff --name-only HEAD~1 HEAD 2>/dev/null | grep '^backend/' || echo 'CHANGED'",
                returnStdout: true
            ).trim()
            if (changes == '') {
                echo "No changes in backend/, skipping build."
                currentBuild.result = 'SUCCESS'
                error("Skipping: no backend changes detected")
            } else {
                echo "Backend changes detected (or history unavailable, building to be safe)."
            }
        }
    }
}
    
    stage('Unit Tests') {
            steps {
                container('node') {
                    dir('backend') {
                        sh 'npm install && npm test'
                    }
                }
            }
        }

    stage('Security Audit') {
            steps {
                container('node') {
                    dir('backend') {
                        sh 'npm install && npm audit --audit-level=critical'
                    }
                }
            }
        }
    

        stage('Build Docker Image') {
            steps {
                dir('backend') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh "echo ${DOCKERHUB_CREDENTIALS_PSW} | docker login -u ${DOCKERHUB_CREDENTIALS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }

    post {
        success {
            echo "✅ Build ${IMAGE_TAG} pushed successfully!"
        }
        failure {
            echo "❌ Build failed."
        }
    }
}
