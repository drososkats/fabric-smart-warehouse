# files that git should ignore (backend)
# Ignore sensitive environment variables
.env

# Ignore heavy dependencies
node_modules/

# Ignore log files
npm-debug.log*

# Ignore OS specific files
.DS_Store

# Runtime user uploads (not source code)
uploads/invoices/*
uploads/product-images/*
!uploads/invoices/.gitkeep
!uploads/product-images/.gitkeep